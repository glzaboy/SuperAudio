<?xml version="1.0" encoding="utf-8"?>
<Window xmlns:winex="using:WinUIEx"
    x:Class="SuperAudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SuperAudio"
    xmlns:viewModels="using:SuperAudio.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SuperAudio">

    <Window.SystemBackdrop>
        <MicaBackdrop/>

    </Window.SystemBackdrop>
    <Grid x:Name="RootGrid" Loaded="RootGrid_Loaded" d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel, IsDesignTimeCreatable=True}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TitleBar
            x:Name="titleBar"
            Title="{Binding Title}"
            IsPaneToggleButtonVisible="{Binding IsPaneToggleButtonVisible}"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind rootFrame.CanGoBack, Mode=OneWay}"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.Resources>
                <!--  TitleBar.Content uses Center alignment by default, which
                  sizes content to its DesiredSize. Override to Stretch so
                  the search box fills the available area up to MaxWidth.  -->
                <HorizontalAlignment x:Key="TitleBarContentHorizontalAlignment">Stretch</HorizontalAlignment>
            </TitleBar.Resources>
            <TitleBar.IconSource>
                <BitmapIconSource UriSource="ms-appx:///Assets/Square44x44Logo.targetsize-256.png" 
                      ShowAsMonochrome="False" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- 左侧可放搜索框或其他内容，这里留空 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                        <!-- 录制按钮 -->
                        <Button 
                x:Name="RecordButton"
                Command="{x:Bind ViewModel.RecordCommand}"
                
                ToolTipService.ToolTip="开始/停止录制"
                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <!-- 红色闪烁圆点 -->
                                <Viewbox Width="16" Height="16">
                                    <Ellipse x:Name="RecordingDot" 
                                         Fill="Red" 
                                         Width="12" 
                                         Height="12" 
                                         Opacity="1" />
                                </Viewbox>
                                <TextBlock Text="{x:Bind ViewModel.RecordButtonText, Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </TitleBar.Content>
        </TitleBar>
        <NavigationView
            x:Name="NavigationViewControl"
            Grid.Row="1"
            Canvas.ZIndex="0"
            DisplayModeChanged="OnPaneDisplayModeChanged"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsTabStop="False"
            Loaded="OnNavigationViewControlLoaded"
            SelectionChanged="OnNavigationViewSelectionChanged">
            <Frame
                x:Name="rootFrame"
                Navigated="OnRootFrameNavigated"
                Navigating="OnRootFrameNavigating" />
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="Home"
                    AutomationProperties.AutomationId="Home"
                    x:Uid="Menu_Home"
                    Tag="HomePage"
                    Icon="Home" />
                
            </NavigationView.MenuItems>
        </NavigationView>
    </Grid>
</Window>
